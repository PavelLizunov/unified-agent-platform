#!/home/uap/.local/share/windows-brat-venv/bin/python
import json
import sys
from pathlib import Path

def powershell_command(args: list[str]) -> str:
    return " ".join(args) or (
        "[pscustomobject]@{Hostname=hostname;Identity=whoami;"
        "OSVersion=[Environment]::OSVersion.VersionString;"
        "WinRM=(Get-Service WinRM).Status.ToString()} | ConvertTo-Json -Compress"
    )


if sys.argv[1:] == ["--self-check"]:
    assert "ConvertTo-Json" in powershell_command([])
    assert powershell_command(["hostname"]) == "hostname"
    print("windows-brat-self-check-ok")
    raise SystemExit

import winrm

command = powershell_command(sys.argv[1:])
config_path = Path.home() / ".config/windows-brat.json"
if config_path.stat().st_mode & 0o077:
    raise SystemExit(f"refusing loose credential permissions: {config_path}")
config = json.loads(config_path.read_text())
result = winrm.Session(
    config["url"],
    auth=(config["username"], config["password"]),
    transport="ntlm",
).run_ps("$ProgressPreference='SilentlyContinue';" + command)
sys.stdout.buffer.write(result.std_out)
sys.stderr.buffer.write(result.std_err)
raise SystemExit(result.status_code)
