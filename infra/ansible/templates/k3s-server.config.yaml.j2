{% if k3s_cluster_init | default(false) %}
cluster-init: true
{% else %}
server: {{ k3s_server_url }}
token-file: /etc/rancher/k3s/token
{% endif %}
node-name: {{ k3s_node_name | default(inventory_hostname) }}
node-ip: {{ tailnet_ip }}
advertise-address: {{ tailnet_ip }}
flannel-iface: tailscale0
tls-san:
  - {{ tailnet_ip }}
{% if tailnet_name is defined and tailnet_name %}
  - {{ tailnet_name }}
{% endif %}
disable:
{% for component in k3s_disable_components %}
  - {{ component }}
{% endfor %}
secrets-encryption: true
write-kubeconfig-mode: "0600"
etcd-snapshot-retention: {{ k3s_snapshot_retention }}
{% if k3s_etcd_s3_enabled | default(false) %}
etcd-s3: true
etcd-s3-config-secret: {{ k3s_etcd_s3_config_secret }}
{% endif %}
